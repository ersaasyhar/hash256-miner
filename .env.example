# Required
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional RPC/contract
# RPC_URL=https://ethereum.publicnode.com
RPC_URLS=https://ethereum.publicnode.com,https://rpc.flashbots.net/fast,https://ethereum-mainnet.gateway.tatum.io,https://eth-mainnet.nodereal.io/v1/1659dfb40aa24bbb8153a677b98064d7
RPC_RETRY_ROUNDS=5
RPC_RETRY_DELAY_MS=1500
CONTRACT_ADDRESS=0xAC7b5d06fa1e77D08aea40d46cB7C5923A87A0cc

# Mining mode: auto | gpu | cpu
MODE=auto

# Throughput tuning
BATCH_SIZE=16000000
THREADS=16
REFRESH_EVERY_BATCHES=10
START_NONCE=0

# Submission
SUBMIT=0

# Optional manual overrides (leave unset for auto-detection)
# EPOCH=250765
# DIFFICULTY_TARGET=0x0000ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
